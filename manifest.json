{
  "manifest_version": 3,
  "name": "ChatMusic - ABC Notation Renderer",
  "description": "Detect ABC music notation in AI chat apps and render sheet music with playback",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab"],
  "web_accessible_resources": [
    {
      "resources": ["soundfonts/FluidR3_GM/acoustic_grand_piano-mp3/*.mp3"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "ChatMusic"
  }
}
